{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/snapshot-settlements",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/snapshot-mae-boletin",
      "schedule": "30 22 * * 1-5"
    }
  ]
}
